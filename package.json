{
  "name": "dokploy-mcp-server",
  "version": "1.5.1",
  "description": "A comprehensive Model Context Protocol (MCP) server for Dokploy - deploy apps, manage containers, databases, domains, and servers.",
  "keywords": [
    "mcp",
    "dokploy",
    "devops",
    "deployment",
    "docker",
    "model-context-protocol",
    "claude",
    "ai-assistant",
    "fastmcp",
    "self-hosted",
    "paas"
  ],
  "author": "Jordan Burke <jordan.burke@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/sapientsai/dokploy-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapientsai/dokploy-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/sapientsai/dokploy-mcp-server/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "dokploy-mcp-server": "dist/bin.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector dist/index.js",
    "start": "pnpm build && node dist/bin.js",
    "serve": "pnpm build && node dist/index.js",
    "openapi:fetch": "tsx scripts/fetch-openapi.ts",
    "openapi:generate": "openapi-typescript openapi.json -o src/generated/dokploy-api.ts --export-type -t",
    "openapi:update": "pnpm openapi:fetch && pnpm openapi:generate && pnpm format"
  },
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastmcp": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "openapi-typescript": "^7.13.0",
    "ts-builds": "^2.7.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
