{
  "name": "dokploy-mcp-server",
  "version": "1.7.4",
  "mcpName": "io.github.sapientsai/dokploy-mcp-server",
  "description": "A comprehensive Model Context Protocol (MCP) server for Dokploy - deploy apps, manage containers, databases, domains, and servers.",
  "keywords": [
    "mcp",
    "dokploy",
    "devops",
    "deployment",
    "docker",
    "model-context-protocol",
    "claude",
    "ai-assistant",
    "fastmcp",
    "self-hosted",
    "paas"
  ],
  "author": "Jordan Burke <jordan.burke@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/sapientsai/dokploy-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapientsai/dokploy-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/sapientsai/dokploy-mcp-server/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "dokploy-mcp-server": "dist/bin.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "validate": "pnpm check:versions && ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "check:versions": "tsx scripts/check-versions.ts",
    "sync:versions": "tsx scripts/sync-versions.ts",
    "version": "pnpm sync:versions",
    "prepublishOnly": "pnpm check:versions && pnpm validate",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector dist/index.js",
    "start": "pnpm build && node dist/bin.js",
    "serve": "pnpm build && node dist/index.js",
    "openapi:fetch": "tsx scripts/fetch-openapi.ts",
    "openapi:generate": "openapi-typescript openapi.json -o src/generated/dokploy-api.ts --export-type -t",
    "openapi:update": "pnpm openapi:fetch && pnpm openapi:generate && pnpm format"
  },
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "@loglayer/transport-pino": "^3.2.0",
    "dotenv": "^17.4.2",
    "functype": "^1.5.0",
    "functype-log": "^1.5.0",
    "loglayer": "^9.3.0",
    "pino": "^10.3.1",
    "somamcp": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "openapi-typescript": "^7.13.0",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
